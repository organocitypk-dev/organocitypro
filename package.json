{
  "name": "organocity",
  "type": "module",
  "version": "4.0.0",
  "description": "A full-stack OrganoCity store built with Next.js, Prisma, NextAuth, and Cloudinary.",
  "license": "MIT",
  "scripts": {
    "start": "next start",
    "dev": "esmate task dev",
    "build": "esmate task build",
    "fix": "esmate task fix",
    "check": "esmate task check",
    "db:migrate": "prisma migrate dev --name replace_shopify_backend",
    "db:generate": "prisma generate",
    "db:seed": "node --experimental-strip-types prisma/seed.ts"
  },
  "dependencies": {
    "@esmate/react": "^3.1.2",
    "@esmate/shadcn": "^3.6.0",
    "@esmate/utils": "^1.3.3",
    "@formspree/react": "^3.0.0",
    "@prisma/client": "^6.6.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.26.1",
    "isomorphic-dompurify": "^2.35.0",
    "next": "^16.1.2",
    "next-auth": "^4.24.13",
    "nextjs-toploader": "^3.9.17",
    "openai": "^6.34.0",
    "prisma": "^6.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "swiper": "^12.0.3",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@esmate/prettier": "^1.0.6",
    "@parcel/watcher": "^2.5.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.4",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.1",
    "esmate": "^2.1.4",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "tasks": {
    "dev": {
      "nextdev": "rimraf .next && next dev"
    },
    "build": [
      "prisma generate",
      "next build"
    ],
    "fix": [
      "esmate fmt",
      "esmate lint --fix"
    ],
    "check": [
      "tsc --noEmit",
      "esmate fmt --check",
      "esmate lint"
    ]
  },
  "postcss": {
    "plugins": [
      "@tailwindcss/postcss"
    ]
  }
}
